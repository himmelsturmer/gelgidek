# ============================================================
# gelgidek.com — Environment Variables
# Bu dosyayı kopyalayıp .env olarak kaydedin
# ============================================================

# JWT Secret — güvenli, uzun, rastgele bir string girin
JWT_SECRET=supersecret-change-this-in-production

# Gmail SMTP
# 1. Google Hesabı → Güvenlik → 2 Adımlı Doğrulama'yı aktif edin
# 2. Google Hesabı → Güvenlik → Uygulama Şifreleri → "Mail" için oluşturun
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM="gelgidek.com <your-gmail@gmail.com>"

# Site adı
SITE_NAME=gelgidek.com

# Admin giriş bilgileri (seed sırasında kullanılır)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
