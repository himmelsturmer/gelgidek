# Prisma Database Config (PostgreSQL / Supabase / Neon vs)
# Supabase veya Neon üzerinden aldığınız Connection String'i buraya yapıştırın.
# Örnek Supabase formatı: DATABASE_URL="postgresql://postgres.[PROJE_ID]:[SIFRE]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"
DATABASE_URL="postgresql://kullanici:sifre@host:5432/veritabani"

# JWT Secret for Admin Panel Auth
JWT_SECRET="bizim-gizli-anahtar-123!"

# E-Posta Ayarları (İletişim Formları için SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="gelgidek@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"
SMTP_FROM="gelgidek@gmail.com"
